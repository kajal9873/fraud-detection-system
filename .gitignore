# ─── Data (large files — download separately) ─────────────────────────────────
data/creditcard.csv
data/*.csv
data/*.zip

# ─── Models (regenerate via train.py) ─────────────────────────────────────────
models/*.json
models/*.bin

# ─── Reports (regenerated on each run) ────────────────────────────────────────
reports/*.png
reports/*.jpg

